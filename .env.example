# Copy to .env and fill in your values
# TMDB: https://www.themoviedb.org/settings/api (Netlify functions, backfill script)
TMDB_API_KEY=
# OMDb: https://www.omdbapi.com/apikey.aspx (add-to-shared-list, fetch-omdb, bookmarklet)
OMDB_API_KEY=
# ISO 3166-1 alpha-2 for watch providers in backfill (default IL)
WATCH_REGION=

# Firebase configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
