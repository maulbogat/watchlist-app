# =============================================================================
# Environment variables — local Node scripts & Netlify functions
# =============================================================================
# Copy to `.env` and fill in values.
#
# • The browser never reads `.env`. Public Firebase web config is in
#   `config/firebase.js` (imported by root `firebase.js`).
# • Netlify: Site settings → Environment variables (for `netlify/functions/*`).
# • Firebase Admin: either `FIREBASE_SERVICE_ACCOUNT` below, or drop
#   `serviceAccountKey.json` in the project root (scripts that support it).
# =============================================================================

# -----------------------------------------------------------------------------
# TMDB (The Movie Database)
# -----------------------------------------------------------------------------
# Key: https://www.themoviedb.org/settings/api
#
# Used by:
#   • Netlify: `add-from-imdb`
#   • Diagnostics: `check-upcoming.mjs` (movies + TV via /tv/{id})
#   • Diagnostics: `compare-upcoming-trakt.mjs` (TMDB side of next-episode compare)
#   • `scripts/*` — metadata sync, trailers, watch providers, verify/backfill, etc.
# -----------------------------------------------------------------------------
TMDB_API_KEY=

# -----------------------------------------------------------------------------
# Trakt.tv (optional)
# -----------------------------------------------------------------------------
# Client ID: https://trakt.tv/oauth/applications (no user OAuth needed for this).
#
# Used only by `compare-upcoming-trakt.mjs` (read-only Trakt search + next_episode).
# Omit if you do not run that script.
# -----------------------------------------------------------------------------
# TRAKT_CLIENT_ID=

# -----------------------------------------------------------------------------
# OMDb (Open Movie Database)
# -----------------------------------------------------------------------------
# Key: https://www.omdbapi.com/apikey.aspx
#
# Used by:
#   • Netlify: `add-from-imdb`
#   • CLI: e.g. `scripts/fetch-omdb.js`, IMDb→TMDB migrations, catalog helpers
# -----------------------------------------------------------------------------
OMDB_API_KEY=

# -----------------------------------------------------------------------------
# Watch region (optional)
# -----------------------------------------------------------------------------
# ISO 3166-1 alpha-2 (e.g. IL, US). TMDB watch-provider / “where to watch”
# tooling. Several scripts default to IL when this is empty.
# -----------------------------------------------------------------------------
WATCH_REGION=

# -----------------------------------------------------------------------------
# Firebase Admin (local / server scripts only)
# -----------------------------------------------------------------------------
# Base64-encoded JSON of your Firebase service account private key — same as
# Netlify’s `FIREBASE_SERVICE_ACCOUNT` if you deploy scripts logic there.
#
# Needed for any script using the Admin SDK against Firestore (backups,
# `check-upcoming.mjs`, `compare-upcoming-trakt.mjs`, recover/migrate helpers).
#
# Encode (macOS/Linux):
#   base64 -i serviceAccountKey.json | tr -d '\n'
# -----------------------------------------------------------------------------
# FIREBASE_SERVICE_ACCOUNT=

# -----------------------------------------------------------------------------
# YouTube Data API (optional — unused by this repo)
# -----------------------------------------------------------------------------
# No checked-in script reads `YOUTUBE_API_KEY`. Safe to omit or keep for your
# own experiments.
# -----------------------------------------------------------------------------
# YOUTUBE_API_KEY=

# -----------------------------------------------------------------------------
# Web app (Firebase client SDK)
# -----------------------------------------------------------------------------
# Not set in `.env`. Use `config/firebase.js` for apiKey, projectId, etc.
