# Environment template
# - Put SERVER/SCRIPT variables in `.env`
# - Put CLIENT/VITE variables in `.env.local`
# - Vercel production: set env vars in the Vercel project (see docs/environment.md for naming).
#
# Client analytics → Axiom uses `/api/log-client-event` with server-only
# `AXIOM_TOKEN` / `AXIOM_DATASET` (no VITE_AXIOM_* — avoids exposing tokens in `dist/`).

# -----------------------------------------------------------------------------
# SERVER / SCRIPTS (for `.env`)
# -----------------------------------------------------------------------------

# Required by Vercel `api/*` routes and most metadata/upcoming scripts
TMDB_API_KEY=
OMDB_API_KEY=
FIREBASE_SERVICE_ACCOUNT=

# Optional: Firestore read quota guard (meta/usageStats). Omit to use defaults below.
FIRESTORE_HOURLY_READ_LIMIT=5000
FIRESTORE_DAILY_READ_LIMIT=45000

# Optional for script behavior
WATCH_REGION=IL
TRAKT_CLIENT_ID=
DEFAULT_WATCH_REGION=IL
REGISTRY_WATCH_REGION=
CATALOG_WATCH_REGION=
USER_UID=

# Local only — scripts/list-my-list-and-our-list-titles.mjs, move-my-list-to-watch-to-archive.mjs
# (resolve "My list": optional WATCHLIST_PERSONAL_LIST_ID → name "My list" → defaultPersonalListId):
# WATCHLIST_MY_LIST_UID=
# WATCHLIST_PERSONAL_LIST_ID=

# Optional: GitHub API token for `/api/admin/external-status?service=github` (Admin — latest backup workflow run).
# Public repos work without it (low rate limit); private repos need a PAT with `actions: read`.
# GITHUB_REPO=owner/repo   # default: maulbogat/watchlist
GITHUB_TOKEN=
# Daily GCS native Firestore export (bucket movie-trailer-site-backups, Cloud Scheduler firestore-daily-export):
# no env vars in this file — configured in Google Cloud (firestore-scheduler SA, lifecycle, etc.). See README Firestore backups.

# Vercel API — `/api/admin/external-status?service=vercel` (Admin — latest deployment). Both required for that card.
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=

# Sentry — server: `whatsapp-webhook`, `add-from-imdb` only (captureException on failures).
SENTRY_DSN=
# Optional Admin card: GET /api/admin/external-status?service=sentry (org maulbogat, project slug below).
# SENTRY_READ_TOKEN=
# SENTRY_PROJECT=

# Optional endpoints/logging (used by Vercel API routes + `log-client-event` for browser logs)
UPCOMING_SYNC_TRIGGER_SECRET=
# Also used by Admin Activity card: GET /api/admin/external-status?service=axiom (APL on dataset watchlist-prod).
AXIOM_TOKEN=
# Do not commit your real dataset name here — some hosts scan repos against env values.
AXIOM_DATASET=

# WhatsApp Cloud API — set in Vercel project env (`/api/whatsapp-webhook`, `/api/whatsapp-verify`).
# WHATSAPP_VERIFY_TOKEN must match Meta's Verify token field exactly (subscription GET).
WHATSAPP_VERIFY_TOKEN=
# App Secret (Meta app) — HMAC verification of POST body (`x-hub-signature-256`) on `/api/whatsapp-webhook`.
WHATSAPP_APP_SECRET=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Optional: public site URL for unregistered-user replies in the webhook (fallback: VERCEL_URL).
# APP_PUBLIC_URL=https://watchlist.maulbogat.com

# Email app invites (Resend) — `POST /api/invites` with action send; invite link base URL.
RESEND_API_KEY=
# Optional; default in code: onboarding@resend.dev (Resend testing domain).
RESEND_FROM_EMAIL=onboarding@resend.dev
# Public origin for links in invite emails (e.g. https://watchlist.vercel.app).
APP_PUBLIC_URL=https://watchlist.vercel.app

# -----------------------------------------------------------------------------
# CLIENT / VITE (for `.env.local`)
# -----------------------------------------------------------------------------

# Required Firebase web config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional Firebase analytics
VITE_FIREBASE_MEASUREMENT_ID=

# Never set VITE_AXIOM_TOKEN / VITE_AXIOM_DATASET — not used; duplicates server AXIOM_* into dist/ and may trip host secret checks.

# Sentry — browser (`src/main.tsx`): only initializes when set; production-only (`enabled: import.meta.env.PROD`). User context is Firebase `uid` only (no email/display name).
VITE_SENTRY_DSN=

# Optional: Vite production build — source map upload to Sentry (set in CI/Vercel when using Sentry releases; omit locally).
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# Optional build metadata (shown in client logs)
VITE_APP_VERSION=1.0.0

# Optional Admin: production URL for “Switch to prod” (default in code: https://watchlist.maulbogat.com)
# VITE_APP_ORIGIN=https://watchlist.maulbogat.com
# Optional Admin: deep link to Vercel deployments page
# VITE_DEPLOYMENTS_URL=https://vercel.com/maulbogats-projects/watchlist/deployments
