# =============================================================================
# Environment variables — local Node scripts & tooling
# =============================================================================
# Copy this file to `.env` and fill in values. The web app does not load `.env`
# (Firebase client config is in `firebase.js`). Netlify uses its own env UI for
# production functions — see README.
#
# Optional: use `serviceAccountKey.json` in the project root instead of
# `FIREBASE_SERVICE_ACCOUNT` where scripts support it.
# =============================================================================

# -----------------------------------------------------------------------------
# TMDB (The Movie Database)
# -----------------------------------------------------------------------------
# Get a key: https://www.themoviedb.org/settings/api
#
# Used by:
#   • Netlify function `add-from-imdb` (production)
#   • `check-upcoming.mjs`, `compare-upcoming-trakt.mjs`
#   • Scripts under `scripts/` that sync metadata, trailers, providers, etc.
# -----------------------------------------------------------------------------
TMDB_API_KEY=

# -----------------------------------------------------------------------------
# Trakt.tv (optional — comparison script only)
# -----------------------------------------------------------------------------
# Create an app: https://trakt.tv/oauth/applications — use the "Client ID".
# Used by: `compare-upcoming-trakt.mjs` (read-only: search by TMDB/IMDb id, next_episode).
# No user OAuth required for this script.
# -----------------------------------------------------------------------------
# TRAKT_CLIENT_ID=

# -----------------------------------------------------------------------------
# OMDb (Open Movie Database)
# -----------------------------------------------------------------------------
# Get a key: https://www.omdbapi.com/apikey.aspx
#
# Used by:
#   • Netlify function `add-from-imdb`
#   • CLI scripts (e.g. `scripts/fetch-omdb.js`, migrations, catalog helpers)
# -----------------------------------------------------------------------------
OMDB_API_KEY=

# -----------------------------------------------------------------------------
# Watch region (optional)
# -----------------------------------------------------------------------------
# ISO 3166-1 alpha-2 country code (e.g. IL, US). Used by some backfill / catalog
# scripts for TMDB “where to watch” data. Many scripts default to IL if unset.
# -----------------------------------------------------------------------------
WATCH_REGION=

# -----------------------------------------------------------------------------
# Firebase Admin — local scripts only
# -----------------------------------------------------------------------------
# Base64-encoded JSON of your Firebase service account (same value as Netlify’s
# `FIREBASE_SERVICE_ACCOUNT`). Required for scripts that talk to Firestore with
# Admin SDK: backups, `check-upcoming.mjs`, recover, migrate, etc.
#
# Generate (macOS/Linux):
#   base64 -i serviceAccountKey.json | tr -d '\n'
# -----------------------------------------------------------------------------
# FIREBASE_SERVICE_ACCOUNT=

# -----------------------------------------------------------------------------
# YouTube Data API (optional — not used by current repo code)
# -----------------------------------------------------------------------------
# No script in this repository reads `YOUTUBE_API_KEY`. Remove this line or
# keep it for your own experiments / future tooling.
# -----------------------------------------------------------------------------
# YOUTUBE_API_KEY=

# -----------------------------------------------------------------------------
# Web app (Firebase client)
# -----------------------------------------------------------------------------
# Not set here. Public web SDK config is in `config/firebase.js`.
