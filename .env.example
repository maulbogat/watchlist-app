# Minimal environment variables used by this repo's scripts/functions.
# Copy to `.env` for local scripts. Configure Netlify secrets in Netlify UI.

# TMDB (required for upcoming sync + metadata/trailer scripts)
TMDB_API_KEY=

# OMDb (required for add-from-imdb and OMDb-based scripts)
OMDB_API_KEY=

# Watch region (optional; scripts default to IL when empty)
WATCH_REGION=

# Trakt client id (optional; used by compare-upcoming-trakt.mjs only)
TRAKT_CLIENT_ID=

# Firebase Admin service account (required by Firestore Admin SDK scripts/functions)
# Encode: base64 -i serviceAccountKey.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT=

# Optional: protect trigger-upcoming-sync endpoint
# UPCOMING_SYNC_TRIGGER_SECRET=

# Note: VITE_FIREBASE_* client variables belong in `.env.local` for Vite.
