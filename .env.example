# =============================================================================
# Environment variables тАФ local Node scripts & Netlify functions
# =============================================================================
# Copy to `.env` (scripts/functions) and `.env.local` (Vite client) as needed.
#
# тАв Vite client vars must be prefixed with `VITE_` and are read from `.env.local`
#   (or `.env`) at build/runtime for the browser bundle.
# тАв Netlify: Site settings тЖТ Environment variables (for `netlify/functions/*`).
# тАв Firebase Admin: either `FIREBASE_SERVICE_ACCOUNT` below, or drop
#   `serviceAccountKey.json` in the project root (scripts that support it).
# =============================================================================

# -----------------------------------------------------------------------------
# TMDB (The Movie Database)
# -----------------------------------------------------------------------------
# Key: https://www.themoviedb.org/settings/api
#
# Used by:
#   тАв Netlify: `add-from-imdb`, scheduled `check-upcoming`, HTTP `trigger-upcoming-sync` (TMDB тЖТ `upcomingAlerts`)
#   тАв Local write: `node scripts/sync-upcoming-alerts.mjs` (full registry тЖТ `upcomingAlerts` if Netlify times out)
#   тАв Diagnostics: `check-upcoming.mjs` (movies + TV via /tv/{id}) тАФ read-only, does not write Firestore
#   тАв Diagnostics: `compare-upcoming-trakt.mjs` (TMDB side of next-episode compare)
#   тАв `scripts/*` тАФ metadata sync, trailers, watch providers, verify/backfill, etc.
# -----------------------------------------------------------------------------
TMDB_API_KEY=

# -----------------------------------------------------------------------------
# Trakt.tv (optional)
# -----------------------------------------------------------------------------
# Client ID: https://trakt.tv/oauth/applications (no user OAuth needed for this).
#
# Used only by `compare-upcoming-trakt.mjs` (read-only Trakt search + next_episode).
# Omit if you do not run that script.
# -----------------------------------------------------------------------------
# TRAKT_CLIENT_ID=

# -----------------------------------------------------------------------------
# OMDb (Open Movie Database)
# -----------------------------------------------------------------------------
# Key: https://www.omdbapi.com/apikey.aspx
#
# Used by:
#   тАв Netlify: `add-from-imdb`
#   тАв CLI: e.g. `scripts/fetch-omdb.js`, IMDbтЖТTMDB migrations, titleRegistry backup tools
# -----------------------------------------------------------------------------
OMDB_API_KEY=

# -----------------------------------------------------------------------------
# Watch region (optional)
# -----------------------------------------------------------------------------
# ISO 3166-1 alpha-2 (e.g. IL, US). TMDB watch-provider / тАЬwhere to watchтАЭ
# tooling. Several scripts default to IL when this is empty.
# -----------------------------------------------------------------------------
WATCH_REGION=

# -----------------------------------------------------------------------------
# Upcoming sync тАФ HTTP trigger secret (Netlify only, optional)
# -----------------------------------------------------------------------------
# If set, `/.netlify/functions/trigger-upcoming-sync` requires:
#   Authorization: Bearer <same value>
# Omit to allow unauthenticated GET/POST (anyone can trigger a sync chunk).
# -----------------------------------------------------------------------------
# UPCOMING_SYNC_TRIGGER_SECRET=

# -----------------------------------------------------------------------------
# Firebase Admin (local / server scripts only)
# -----------------------------------------------------------------------------
# Base64-encoded JSON of your Firebase service account private key тАФ same as
# NetlifyтАЩs `FIREBASE_SERVICE_ACCOUNT` if you deploy scripts logic there.
#
# Needed for any script using the Admin SDK against Firestore (backups,
# `check-upcoming.mjs`, Netlify `check-upcoming` + `add-from-imdb` upcoming sync,
# `compare-upcoming-trakt.mjs`, recover/migrate helpers).
#
# Encode (macOS/Linux):
#   base64 -i serviceAccountKey.json | tr -d '\n'
# -----------------------------------------------------------------------------
# FIREBASE_SERVICE_ACCOUNT=

# -----------------------------------------------------------------------------
# YouTube Data API (optional тАФ unused by this repo)
# -----------------------------------------------------------------------------
# No checked-in script reads `YOUTUBE_API_KEY`. Safe to omit or keep for your
# own experiments.
# -----------------------------------------------------------------------------
# YOUTUBE_API_KEY=

# -----------------------------------------------------------------------------
# Web app (Firebase client SDK)
# -----------------------------------------------------------------------------
# Used by `src/config/firebase.ts` via `import.meta.env`.
# Mirror these in Netlify for production builds.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
