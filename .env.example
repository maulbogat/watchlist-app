# Environment template
# - Put SERVER/SCRIPT variables in `.env`
# - Put CLIENT/VITE variables in `.env.local`
# - Vercel production: set env vars in the Vercel project (see docs/netlify-environment.md for naming).
#
# Client analytics → Axiom uses `/api/log-client-event` with server-only
# `AXIOM_TOKEN` / `AXIOM_DATASET` (no VITE_AXIOM_* — avoids exposing tokens in `dist/`).

# -----------------------------------------------------------------------------
# SERVER / SCRIPTS (for `.env`)
# -----------------------------------------------------------------------------

# Required by Vercel `api/*` routes and most metadata/upcoming scripts
TMDB_API_KEY=
OMDB_API_KEY=
FIREBASE_SERVICE_ACCOUNT=

# Optional for script behavior
WATCH_REGION=IL
TRAKT_CLIENT_ID=
DEFAULT_WATCH_REGION=IL
REGISTRY_WATCH_REGION=
CATALOG_WATCH_REGION=
USER_UID=

# Optional: GitHub API token for `github-backup-status` (Admin page — latest backup workflow run).
# Public repos work without it (low rate limit); private repos need a PAT with `actions: read`.
# GITHUB_REPO=owner/repo   # default: maulbogat/movie-trailer-site
GITHUB_TOKEN=

# Optional endpoints/logging (used by Vercel API routes + `log-client-event` for browser logs)
UPCOMING_SYNC_TRIGGER_SECRET=
AXIOM_TOKEN=
# Do not commit your real dataset name here — Netlify secret scanning matches this file against env.
AXIOM_DATASET=

# WhatsApp Cloud API — set in Vercel project env (`/api/whatsapp-webhook`, `/api/whatsapp-verify`).
# WHATSAPP_VERIFY_TOKEN must match Meta's Verify token field exactly (subscription GET).
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Optional: public site URL for unregistered-user replies in the webhook (fallback: VERCEL_URL).
# APP_PUBLIC_URL=https://watchlist-trailers.vercel.app

# Optional: VITE_SITE_ID in .env.local — echoed as configured in `admin-env-status` (not secret). Legacy Netlify fallbacks:
# VITE_NETLIFY_SITE_ID=   # optional legacy deploy badge UUID
# NETLIFY_SITE_ID=

# -----------------------------------------------------------------------------
# CLIENT / VITE (for `.env.local`)
# -----------------------------------------------------------------------------

# Required Firebase web config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional Firebase analytics
VITE_FIREBASE_MEASUREMENT_ID=

# Never set VITE_AXIOM_TOKEN / VITE_AXIOM_DATASET — not used; breaks Netlify secret scan if values match server AXIOM_*.

# Optional build metadata (shown in client logs)
VITE_APP_VERSION=1.0.0

# Optional Admin: production URL for service links / bookmarklet (default in code: watchlist-trailers.vercel.app)
# VITE_APP_ORIGIN=https://watchlist-trailers.vercel.app
# Optional Admin: deep link to Vercel deployments page
# VITE_DEPLOYMENTS_URL=https://vercel.com/<team>/<project>/deployments
# Optional: marks SITE_ID as set in admin-env-status API
# VITE_SITE_ID=
# Legacy Netlify deploy badge only (site UUID from Netlify)
# VITE_NETLIFY_SITE_ID=
# VITE_NETLIFY_PROJECT_SLUG=
