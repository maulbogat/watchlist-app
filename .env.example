# Environment template
# - Put SERVER/SCRIPT variables in `.env`
# - Put CLIENT/VITE variables in `.env.local`
# - Netlify production: see docs/netlify-environment.md (delete VITE_AXIOM_* in Netlify UI)
#
# Client analytics → Axiom uses `/.netlify/functions/log-client-event` with server-only
# `AXIOM_TOKEN` / `AXIOM_DATASET` (no VITE_AXIOM_* — avoids exposing tokens in `dist/`).

# -----------------------------------------------------------------------------
# SERVER / SCRIPTS (for `.env`)
# -----------------------------------------------------------------------------

# Required by Netlify functions and most metadata/upcoming scripts
TMDB_API_KEY=
OMDB_API_KEY=
FIREBASE_SERVICE_ACCOUNT=

# Optional for script behavior
WATCH_REGION=IL
TRAKT_CLIENT_ID=
DEFAULT_WATCH_REGION=IL
REGISTRY_WATCH_REGION=
CATALOG_WATCH_REGION=
USER_UID=

# Optional: GitHub API token for `github-backup-status` (Admin page — latest backup workflow run).
# Public repos work without it (low rate limit); private repos need a PAT with `actions: read`.
# GITHUB_REPO=owner/repo   # default: maulbogat/movie-trailer-site
GITHUB_TOKEN=

# Optional endpoints/logging (used by Netlify functions + `log-client-event` for browser logs)
UPCOMING_SYNC_TRIGGER_SECRET=
AXIOM_TOKEN=
# Do not commit your real dataset name here — Netlify secret scanning matches this file against env.
AXIOM_DATASET=

# WhatsApp Cloud API (`whatsapp-webhook` Netlify function). Set in Netlify with Functions scope.
# WHATSAPP_VERIFY_TOKEN must match Meta's Verify token field exactly (subscription GET).
WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_TOKEN=          # permanent access token (sending messages / Graph API)
# WHATSAPP_PHONE_NUMBER_ID=

# Site UUID: use only VITE_NETLIFY_SITE_ID in .env.local (functions read it too). Do not duplicate as NETLIFY_SITE_ID
# if Netlify marks it secret — same value in dist/ triggers secret scanning. Legacy optional fallback:
# NETLIFY_SITE_ID=

# -----------------------------------------------------------------------------
# CLIENT / VITE (for `.env.local`)
# -----------------------------------------------------------------------------

# Required Firebase web config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional Firebase analytics
VITE_FIREBASE_MEASUREMENT_ID=

# Never set VITE_AXIOM_TOKEN / VITE_AXIOM_DATASET — not used; breaks Netlify secret scan if values match server AXIOM_*.

# Optional build metadata (shown in client logs)
VITE_APP_VERSION=1.0.0

# Optional Admin page: Netlify "Last deployment" status badge (Site configuration → General → Site details → Site ID)
VITE_NETLIFY_SITE_ID=
# Optional: only if your Netlify project slug differs from watchlist-trailers
# VITE_NETLIFY_PROJECT_SLUG=
