# Environment template
# - Put SERVER/SCRIPT variables in `.env`
# - Put CLIENT/VITE variables in `.env.local`
# - Netlify production secrets should be configured in Netlify UI

# -----------------------------------------------------------------------------
# SERVER / SCRIPTS (for `.env`)
# -----------------------------------------------------------------------------

# Required by Netlify functions and most metadata/upcoming scripts
TMDB_API_KEY=
OMDB_API_KEY=
FIREBASE_SERVICE_ACCOUNT=

# Optional for script behavior
WATCH_REGION=IL
TRAKT_CLIENT_ID=
DEFAULT_WATCH_REGION=IL
REGISTRY_WATCH_REGION=
CATALOG_WATCH_REGION=
USER_UID=

# Optional endpoints/logging
UPCOMING_SYNC_TRIGGER_SECRET=
AXIOM_TOKEN=
AXIOM_DATASET=watchlist-prod

# -----------------------------------------------------------------------------
# CLIENT / VITE (for `.env.local`)
# -----------------------------------------------------------------------------

# Required Firebase web config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional Firebase analytics
VITE_FIREBASE_MEASUREMENT_ID=

# Optional client observability
VITE_AXIOM_TOKEN=
VITE_AXIOM_DATASET=
VITE_APP_VERSION=1.0.0
