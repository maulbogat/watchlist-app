{
  "buildCommand": "npm run build:react",
  "outputDirectory": "dist",
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }],
  "crons": [{ "path": "/api/check-upcoming", "schedule": "0 3 * * *" }],
  "functions": {
    "api/check-upcoming.js": { "maxDuration": 60 },
    "api/trigger-upcoming-sync.js": { "maxDuration": 60 },
    "api/add-from-imdb.js": { "maxDuration": 60 }
  }
}
