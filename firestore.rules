rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Canonical title metadata (written by Netlify functions / Admin SDK only)
    match /titleRegistry/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    // `displayName` is readable by any signed-in user (shared list “added by” labels).
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // Extra personal lists (not the default doc on users/{uid})
    match /users/{userId}/personalLists/{listId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /sharedLists/{listId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.members;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.members;
      allow update, delete: if request.auth != null && request.auth.uid in resource.data.members;
    }
    // TMDB-derived upcoming titles (written only by Netlify scheduled function + Admin SDK)
    match /upcomingAlerts/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    // Cursor for chunked upcoming sync (Admin SDK only)
    match /syncState/{docId} {
      allow read, write: if false;
    }

    // Firestore read quota stats (Admin SDK writes). Client read: admin UIDs only — same list as src/config/admin.ts
    match /meta/{docId} {
      allow read: if request.auth != null && request.auth.uid in ['fSyHdUXB56fBTeKlNFXPiAq1Lip2'];
      allow write: if false;
    }

    // WhatsApp sender → uid + default list (client may update/delete own mapping; Admin used for verify)
    match /phoneIndex/{phone} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // 6-digit link codes (Admin SDK only)
    match /verificationCodes/{docId} {
      allow read, write: if false;
    }

    // App access allowlist (Admin SDK writes). Users may read their own row only.
    match /allowedUsers/{email} {
      allow read: if request.auth != null
        && request.auth.token.email != null
        && email.lower() == request.auth.token.email.lower();
      allow write: if false;
    }

    // Email invites (Admin SDK writes). Authenticated read for optional client introspection.
    match /invites/{inviteId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
